    <!--
        Accessibility Service description.
        Shown in the system Accessibility Settings page.
    -->
    <string name="accessibility_service_description">
        Appause uses this service to detect when you open apps that you have chosen to pause.
        It only reads which app is currently in the foreground. It does not collect,
        record, or transmit any personal data.
    </string>

